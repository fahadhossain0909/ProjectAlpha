ENVIRONMENT=dev
LOG_LEVEL=INFO
REQUIRE_HUMAN_APPROVAL_FOR_PROD=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=aitos

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Only needed for LIVE order execution (aitos.execution.binance_executor).
# Leave BINANCE_TESTNET=true until you deliberately mean to trade mainnet.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_RECV_WINDOW_MS=5000
# Only if your Binance account uses hedge (dual-side position) mode —
# leave false for the default one-way mode.
BINANCE_HEDGE_MODE=false
