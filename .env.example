# Example Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# ============================================
# Application Environment
# ============================================
ENVIRONMENT=dev
LOG_LEVEL=INFO
REQUIRE_HUMAN_APPROVAL_FOR_PROD=true

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# ClickHouse Configuration
# ============================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=aitos

# ============================================
# Neo4j Configuration
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ============================================
# Binance Trading Configuration
# Only needed for LIVE order execution (aitos.execution.binance_executor).
# Leave BINANCE_TESTNET=true until you deliberately mean to trade mainnet.
# ============================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_RECV_WINDOW_MS=5000
# Only if your Binance account uses hedge (dual-side position) mode —
# leave false for the default one-way mode.
BINANCE_HEDGE_MODE=false

# ============================================
# Deployment Configuration (GitHub Actions)
# ============================================
DEPLOY_HOST=your_deploy_server_ip_or_hostname
DEPLOY_USER=deploy_user
DEPLOY_PORT=22
APP_PORT=8000
APP_HOST=0.0.0.0

# ============================================
# Docker Compose
# ============================================
COMPOSE_PROJECT_NAME=projectalpha
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_github_username

# ============================================
# Security & Debugging
# ============================================
DEBUG=false
TESTING=false
SECRET_KEY=your_app_secret_key
API_KEY=your_api_key
DATABASE_URL=

# ============================================
# Third-Party Services (Optional)
# ============================================
SENTRY_DSN=
SLACK_WEBHOOK_URL=
